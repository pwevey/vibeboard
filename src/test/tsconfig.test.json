{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "../../dist/test",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "paths": {
      "vscode": ["../../src/test/vscode-mock"]
    }
  },
  "include": [
    "../storage/models.ts",
    "../utils/uuid.ts",
    "../utils/constants.ts",
    "../tasks/TaskManager.ts",
    "../session/SessionManager.ts",
    "../storage/StorageProvider.ts",
    "./**/*.ts"
  ]
}
